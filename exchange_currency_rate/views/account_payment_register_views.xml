<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form_inherit_exchange_currency_rate" model="ir.ui.view">
        <field name="name">account.payment.register.form.inherit.exchange.currency.rate</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_date']" position="after">
                <field name="is_exchange"/>
                <field name="rate" digits="[12,6]"/>
                <field name="rate_display" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
