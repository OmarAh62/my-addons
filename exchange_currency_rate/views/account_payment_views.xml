<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_inherit_exchange_currency_rate" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.exchange.currency.rate</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="is_exchange"
                       invisible="currency_id == company_currency_id"
                       readonly="state not in ('draft', 'in_process')"/>
                <field name="rate"
                       digits="[12,6]"
                       invisible="not is_exchange or currency_id == company_currency_id"
                       readonly="state not in ('draft', 'in_process')"/>
                <field name="rate_display"
                       string="Exchange Rate"
                       invisible="currency_id == company_currency_id"
                       readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
