<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.exchange.currency.rate</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="is_exchange"
                       invisible="currency_id == company_currency_id"
                       readonly="state != 'draft'"/>
                <field name="rate"
                       digits="[12,6]"
                       invisible="not is_exchange or currency_id == company_currency_id"
                       readonly="state != 'draft'"/>
                <field name="rate_display"
                       invisible="currency_id == company_currency_id"
                       readonly="1"
                       string="Exchange Rate"/>
            </xpath>
            <xpath expr="//field[@name='invoice_currency_rate']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
